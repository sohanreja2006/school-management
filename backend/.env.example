# --- SaaS / production (required when NODE_ENV=production) ---
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-at-least-32-random-characters-long
JWT_EXPIRES_IN=30d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (tenant registry + Postgres-backed school data)
SUPABASE_URL=
SUPABASE_KEY=

# MongoDB (optional: used for some Mongoose models e.g. payment verification)
MONGO_URI=

# Frontend should point here (Vite)
# VITE_API_URL=http://localhost:5000/api
